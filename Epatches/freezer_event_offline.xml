	<!-- This happens in the function that inits the fs event structure (which is called from VCControl ctor) 
		 Probably a sub-class/struct of the VCControl object -->
	<!-- This patch is very dependent of the DLL side. In concrete, fs_event_online.cpp: sizeof(orig_ins1) and patch_addr1 in IsFreezerEventEndingPatched  (the two jz will be noped at runtime) -->
	<Patch name="LocateSetIsFsEventHappening" type="notify" search_start="0x4015C8" comment="signature 1.26" >
		<Instruction code="48 89 6C 24 68" comment="mov [rsp+68h], rbx" />
		<Instruction code="E8 XX XX XX XX" comment="call is_logged_in" />
		<Instruction code="85 C0" comment="test eax, eax" />
		<Instruction code="74 14" comment="jz +0x14" />
		<Instruction code="83 FD FF" comment="cmp ebx, -1" />
		<Instruction code="74 0F" comment="jz +0xF" />
		<Instruction code="C7 83 14 01 00 00 01 00 00 00" comment="mov object->is_freezer_event_happening = 1" />
		<Instruction code="BF 01 00 00 00" comment="mov edi, 1" />
		
		<Notify inst_index="3" value="OnSetIsFsEventHappeningLocated" />
	</Patch>
	
