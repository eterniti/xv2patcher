	<!-- These two patches replace the functionality of the previous patch -->

	<!-- 1.26: the old hook + SetupAllies doesn't work anymore. the fill loop keeps num_allies in a
	     register now (r13d = edi+1 = 2) instead of the [rbp-0x28] stack local the DLL used to write, so
	     the hook can't touch it. just bump the constant instead: lea r13d,[rdi+1] (=2) becomes [rdi+4] (=5).
	     loop is at 0x3AB952, one ally per pass, slot stride 0x1F0, decrements r13. -->
	<Patch name="MultiSelectExpert_Patch_NumAllies" type="write" enabled="enable_multiselect_expert" search_start="0x3AB937" comment="signature 1.26; sets battle ally count to 5">
		<Instruction code="BF 01 00 00 00" comment="mov edi, 1 ; first ally index" />
		<Instruction code="4C 8D BD 44 01 00 00" comment="lea r15, [rbp+144h]" />
		<Instruction code="4C 8B 65 C8" comment="mov r12, [rbp-38h]" />
		<Instruction code="49 81 C4 74 02 00 00" comment="add r12, 274h" />
		<Instruction code="44 8D 6F 01" comment="lea r13d, [rdi+1] ; num_allies = 2" />

		<!-- lea r13d,[rdi+1] -> lea r13d,[rdi+4] : ally count 2 -> 5 -->
		<Write inst_index="4" inst_offset="3" value="04" />
	</Patch>


