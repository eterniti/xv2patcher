<?xml version="1.0" encoding="utf-8" ?>
<EternityPatchFile name="BattleTimer" enabled="battle_timer" comment="This file enables battle timer patch">

	<!-- On signature change, whatch out the offset of the constant in first instruction. x64 specific registers increase instruction length by one, like it happened in 1.09->1.10v2 -->
	<Patch name="BattleTimer" type="notify" search_start="0x3A9C8A" comment="signature 1.26" >

		<Instruction code="C7 46 08 00 00 34 43" comment="mov dword ptr [rsi+8], 43340000h; 180.0" />
		<Instruction code="EB 04" comment="jmp +4" />
		<Instruction code="44 89 7E 08" comment="mov [rsi+8], r15d" />
		<Instruction code="49 8B CF" comment="mov rcx, r15" />

		<Notify inst_index="0" inst_offset="3" value="BattleTimer" />

	</Patch>

</EternityPatchFile>