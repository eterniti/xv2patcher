	<!-- New patch for 1.25.1. Same function as above. This patch has been added to ensure the offset where mob is matches the DLL. 
	     This had been stable at offset 0 since beginning of game, suddenly it changed to 0x10.
	     On change of the offset, update the value in SkillCommandPatched -->
	<Patch name="CheckSkillCommandMob" type="notify" search_start="0xF4011" comment="signature 1.26">
		<Instruction code="48 8B 43 10" comment="mov rax, [rbx+10h]" />
		<Instruction code="F7 40 5C 00 00 08 00" comment="test dword [rax+5Ch], 80000h" />
		<Instruction code="0F 84 XXXXXXXX" comment="je" />
		<Instruction code="48 83 B8 E8 04 00 00 00" comment="cmp qword [rax+4E8h], 0" />

		<Notify value="NULL" />
	</Patch>
	
