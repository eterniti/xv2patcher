<?xml version="1.0" encoding="utf-8" ?>
<!-- This file enables extensions to the AI -->
<EternityPatchFile name="AIExtend" enabled="ai_extend" >

	<!-- 
	
		A change in the signature may indicate changes in the structure of params XG::Game::Battle::Core::MainSystem(rcx) and "SelectCharInfo"(rdx), 
		which would need to update the code in the DLL. 
		
		XG::Game::Battle::Core::MainSystem: 0x3A58 (mobs), unk_mob_data (0xE0)
		"SelectCharInfo": 0, (char_index), 0x4 (char_index2), 0xC (is_cpu), 0x10(team) 
		UnkMobStruct: sizeof() = 0x1F0
	-->
	<Patch name="PatchOnBattleCreateChar" type="hook" search_start="0x158D20" comment="signature 1.26">
		<Instruction code="40 55 41 54 41 55 41 56 41 57" comment="push rbp,r12,r13,r14,r15" />
		<Instruction code="48 8D AC 24 F0 F9 FF FF" comment="lea rbp, [rsp-610h]" />
		<Instruction code="48 81 EC 10 07 00 00" comment="sub rsp, 710h" />
		<Instruction code="48 8B 05 XXXXXXXX" comment="mov rax, [rip+canary]" />
		<Instruction code="48 33 C4" comment="xor rax, rsp" />
		<Instruction code="48 89 85 F0 05 00 00" comment="mov [rbp+5F0h], rax" />

		<Hook value="OnBattleCreateCharPatched" setup="SetupAIExtend" />
	</Patch>
	
	<!-- A signature change here could mean that the AIDef struct/r8 needs update -->
	<!-- 0x30: mob -->	
	<Patch name="PatchAISpecial" type="hook" search_start="0x8D830" >
		<Instruction code="48 89 5C 24 08" comment="mov [rsp+8], rbx" />
		<Instruction code="48 89 6C 24 10" comment="mov [rsp+10h], rbp" />
		<Instruction code="48 89 74 24 20" comment="mov [rsp+20h], rsi" />
		<Instruction code="57 41 56 41 57" comment="push rdi, r14, r15" />
		<Instruction code="48 83 EC 20" comment="sub rsp, 20h" />
		<Instruction code="49 8B 40 40" comment="mov rax, [r8+40h]" />
		<Instruction code="49 8B D8" comment="mov rbx, r8" />
		<Instruction code="4C 8B F2" comment="mov r14, rdx" />
		<Instruction code="48 8B F9" comment="mov rdi, rcx" />
		<Instruction code="48 85 C0" comment="test rax, rax" />

		<Hook value="AISpecialPatched" setup="SetupAISpecial" />
	</Patch>
	
