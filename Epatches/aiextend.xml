		<Instruction code="83 F8 0C" comment="cmp eax, 0Ch" />

		<Notify value="NULL" />
	</Patch>
	
	<!-- Signature 1.24.1 -->
	<Patch name="PatchSkillCommand" type="hook" search_start="0xF3CE0" >
		<Instruction code="48 8B C4" comment="mov rax, rsp" />
		<Instruction code="53 41 56" comment="push rbx, r14" />
		<Instruction code="48 83 EC 78" comment="sub rsp, 78h" />
