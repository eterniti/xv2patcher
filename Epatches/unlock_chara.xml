<?xml version="1.0" encoding="utf-8" ?>
<EternityPatchFile name="UnlockChara" comment="This file enables the unlock of characters without modifying save data or any other files.">

	<!-- Signature 1.26 (base reg rcx->rdi, one insn reordered; call now inst_index 3) -->
	<Patch name="UnlockCharaMods" type="hook" search_start="0x5E4A62" enabled="unlock_chara_mods" >
		<Instruction code="44 8B 87 3C 04 00 00" comment="mov r8d, [rdi+43Ch]" />
		<Instruction code="48 8B CF" comment="mov rcx, rdi" />
		<Instruction code="8B 97 38 04 00 00" comment="mov edx, [rdi+438h]" />
		<Instruction code="E8 XXXXXXXX" comment="call check_unlock" />
		<Instruction code="44 8B C0" comment="mov r8d, eax" />

		<Hook type="call" inst_index="3" value="UnlockCharaMods" setup="SetupCheckUnlockFunction" />
	</Patch>

	<!-- This patch has same signature as above. It is important that this patch is below the previous one. -->
	<Patch name="UnlockCharaAll" type="write" search_start="0x5E4A62" enabled="unlock_chara_all" >
		<Instruction code="44 8B 87 3C 04 00 00" comment="mov r8d, [rdi+43Ch]" />
		<Instruction code="48 8B CF" comment="mov rcx, rdi" />
		<Instruction code="8B 97 38 04 00 00" comment="mov edx, [rdi+438h]" />
		<Instruction code="E8 XXXXXXXX" comment="call check_unlock" />
		<Instruction code="44 8B C0" comment="mov r8d, eax" />

		<Write inst_index="3" value="41 B8 01 00 00 00    9090" comment="mov r8d, 1; nop; nop;" />
	</Patch>

</EternityPatchFile>